{
  "name": "macrometric",
  "version": "1.2.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --env-file=.env.api.local ./node_modules/tsx/dist/cli.mjs watch server/index.ts",
    "dev:db": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d postgres",
    "dev:db:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml stop postgres",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start:api": "node dist-server/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@isaacs/brace-expansion": "^5.0.1",
    "@supabase/supabase-js": "^2.57.4",
    "bcryptjs": "^3.0.3",
    "fast-decode-uri-component": "^1.0.1",
    "fastify": "^5.8.4",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tesseract.js": "^7.0.0",
    "vercel": "^50.39.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
